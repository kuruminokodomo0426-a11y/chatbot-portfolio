# Anthropic（Claude）API — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# モデルID（未設定時は claude-sonnet-4-20250514）。エラーなら公式ドキュメントの利用可能モデルに変更。
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 相談用 Google フォームなどの URL（必須推奨）
CONTACT_FORM_URL=https://docs.google.com/forms/

# あなたのサービス内容（Claude の前提知識）。長文はダブルクォートで囲むと複数行にできます。
# SERVICE_CONTEXT="提供内容の要約。得意分野。対応エリア。よくある相談など。"
